#!/bin/sh
. "$(dirname "$0")/_/h"

current_branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$current_branch" = "main" ] && [ "${ALLOW_MAIN_COMMIT:-}" != "1" ]; then
  echo "Direct commits on main are blocked. Create a branch first or set ALLOW_MAIN_COMMIT=1 for an explicit override."
  exit 1
fi

npm run lint-staged
npm run lint
npm run typecheck
npm run test
npm run check-filenames
