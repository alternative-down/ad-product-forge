{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "agent-runtime-core": [
        "../agent-runtime-core/dist/core-entry.d.ts"
      ],
      "agent-runtime-core/integrations": [
        "../agent-runtime-core/dist/integrations-entry.d.ts"
      ]
    },
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", ".turbo", "dist", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
