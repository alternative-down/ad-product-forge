{
  "name": "@forge-runtime/core",
  "version": "0.1.0",
  "description": "Forge runtime core package.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run -w agent-runtime-core build && tsup && tsc -p tsconfig.json --emitDeclarationOnly",
    "typecheck": "npm run -w agent-runtime-core build && tsc --noEmit",
    "lint": "eslint --config ../../eslint.config.node.mjs \"src/**/*.ts\"",
    "test": "npm run -w agent-runtime-core build && vitest run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/openai": "^3.0.52",
    "@huggingface/transformers": "3.7.5",
    "@libsql/client": "^0.15.15",
    "agent-runtime-core": "file:../agent-runtime-core",
    "ai": "^6.0.168",
    "fastembed": "^2.1.0",
    "js-tiktoken": "^1.0.21",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
