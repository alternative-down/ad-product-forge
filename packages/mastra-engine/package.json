{
  "name": "@mastra-engine/core",
  "version": "0.1.0",
  "description": "Mastra Agent Engine Factory",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node ./scripts/fix-dist-import-specifiers.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --config ../../eslint.config.node.mjs \"src/**/*.ts\"",
    "smoke:openai-codex": "tsx examples/openai-codex-smoke.ts",
    "smoke:claude-max": "tsx examples/claude-max-smoke.ts",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:push": "drizzle-kit push"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/openai": "^3.0.47",
    "@libsql/client": "^0.17.2",
    "@mastra/core": "^1.15.0",
    "@mastra/fastembed": "^1.0.0",
    "@mastra/libsql": "^1.7.1",
    "@mastra/memory": "^1.9.0",
    "@mendable/firecrawl-js": "^4.15.4",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
