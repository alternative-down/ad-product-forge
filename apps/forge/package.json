{
  "name": "forge-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "npm run -w @mastra-engine/core build && tsup && mkdir -p dist/skills && cp -R src/agents/skills/. dist/skills/",
    "typecheck": "npm run -w @mastra-engine/core build && tsc --noEmit",
    "lint": "eslint --config ../../eslint.config.node.mjs \"src/**/*.ts\"",
    "init-registry": "tsx src/scripts/init-agent-registry.ts",
    "reset-embedder-indexes": "tsx src/scripts/reset-agent-embedder-indexes.ts",
    "fund-cash": "tsx src/scripts/fund-company-cash.ts",
    "top-up-contract": "tsx src/scripts/top-up-agent-contract.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@huggingface/transformers": "3.7.5",
    "@mastra-engine/core": "0.1.0",
    "@mastra/core": "^1.24.1",
    "@mastra/mcp": "^1.4.2",
    "@octokit/auth-app": "^8.1.1",
    "@types/node-schedule": "^2.1.8",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.1",
    "fflate": "^0.8.2",
    "imapflow": "^1.3.1",
    "nanoid": "^5.1.7",
    "node-schedule": "^2.1.1",
    "nodemailer": "^8.0.5",
    "octokit": "^5.0.3",
    "onnxruntime-node": "1.21.0",
    "postal-mime": "^2.7.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
