{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": ["node"],
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@mastra-engine/core": ["../../packages/mastra-engine/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", ".turbo", "dist"]
}
