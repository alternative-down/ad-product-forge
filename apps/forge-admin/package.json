{
  "name": "forge-admin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "start": "sh -c 'serve -s dist -l tcp://0.0.0.0:${FORGE_ADMIN_PORT:-3021}'",
    "lint": "eslint --config ./eslint.config.js \"src/**/*.ts\"",
