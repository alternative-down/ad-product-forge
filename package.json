{
  "name": "ad-product-forge",
  "private": true,
  "version": "0.1.3",
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "prepare": "husky",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "lint-staged": "lint-staged",
    "verify-deps": "node scripts/verify-deps-versions.js",
    "verify-deps:fix": "node scripts/verify-deps-versions.js --fix",
    "check-filenames": "node scripts/kebab-case-check.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@types/chai": "^5.2.3",
    "@types/node": "^25.5.2",
    "eslint": "^9.39.4",
    "fallow": "^2.62.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.19"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "ai": "^6.0.168"
  },
  "overrides": {
    "zod": "^3.25.76",
    "@ai-sdk/anthropic": "^3.0.71",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.3",
    "ai": "^6.0.168",
    "@libsql/client": "^0.15.15"
  }
}
