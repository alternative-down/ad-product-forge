{
  "name": "ad-product-forge",
  "private": true,
  "version": "0.1.3",
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "prepare": "husky",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.19"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@mastra/core": "^1.25.0",
    "@mastra/rag": "^2.2.0",
    "ai": "^6.0.154"
  }
}
